{
    "manifest_version": 3,
    "name": "Lms Expand Tools",
    "version": "1.0",

    "options_ui": {"page": "options/options.html"},

    "description": "A FireFox extension to expand LMS tools for better user experience.",

    "icons": {
        "48": "icons/Lms-Expand-Tools-48.png"
    },

    "action": {
    "default_title": "Lms Expand Tools"
    },

    "background": {
        "scripts": ["background/background.js"]
    },

    "content_scripts": [
        {
            "matches": ["*://*.acanthus.cis.kanazawa-u.ac.jp/*"],
            "js": ["script/script.js"]
        }
    ],

    "permissions": [
        "storage", "tabs"
    ]
}